# Ollama model for decomposition and assembly (large, capable model)
CLOUD_MODEL=gpt-oss:120b-cloud
# Alternative: CLOUD_MODEL=gemma4:31b-cloud

# Ollama model for micro-task execution (coding/logic)
LOCAL_CODER_MODEL=qwen2.5-coder:1.5b

# Ollama model for micro-task execution (text/general)
LOCAL_GENERAL_MODEL=qwen2.5:1.5b
# Alternative: LOCAL_GENERAL_MODEL=ministral-3:3b-cloud

# Stage-specific model overrides (balanced preset)
# Keep planning strongest:
MODEL_DECOMPOSER=gpt-oss:120b-cloud
# Use a smaller cloud model for assembly/final checks/reflection:
MODEL_ASSEMBLER_CLOUD=ministral-3:3b-cloud
MODEL_REFLECTOR_CLOUD=ministral-3:3b-cloud
MODEL_FINAL_VERIFY_CLOUD=ministral-3:3b-cloud
MODEL_CLARIFIER_CLOUD=ministral-3:3b-cloud
# Keep local execution and tool routing fast:
MODEL_EXECUTOR_CODER=qwen2.5-coder:1.5b
MODEL_EXECUTOR_GENERAL=qwen2.5:1.5b
MODEL_TOOL_ROUTER=functiongemma:latest
MODEL_CLARIFIER_LOCAL=qwen2.5:1.5b
MODEL_FINAL_VERIFY_LOCAL_CODER=qwen2.5-coder:1.5b
MODEL_FINAL_VERIFY_LOCAL_GENERAL=qwen2.5:1.5b

# Reflection strategy
REFLECT_USE_CLOUD=true

# ---------------------------------------------------------------------------
# OLLAMA CONFIGURATION
# ---------------------------------------------------------------------------

# Ollama server URL
OLLAMA_URL=http://localhost:11434

# Optional auth for Ollama-compatible proxies/gateways
# Uncomment and replace with your actual API key if using a proxy
#OLLAMA_API_KEY="your_api_key_here"
#OLLAMA_BEARER_TOKEN="your_bearer_token_here"

# ---------------------------------------------------------------------------
# EXECUTION CONTROL
# ---------------------------------------------------------------------------

# Execution mode: "sequential" (default, more reliable) or "parallel" (faster)
EXECUTION_MODE=sequential

# Maximum parallel tasks when in parallel mode
MAX_PARALLEL=6

# Timeout settings (seconds)
LOCAL_TIMEOUT=120
CLOUD_TIMEOUT=180

# ---------------------------------------------------------------------------
# RETRY STRATEGY
# ---------------------------------------------------------------------------

# General retry settings
MAX_RETRIES=3
DECOMPOSITION_MAX_RETRIES=6
MAX_REPLANS=2
FINAL_ASSEMBLY_VERIFY_RETRIES=2
FINAL_WRITE_VERIFY_RETRIES=3

# Retry behavior
RETRY_TEMPERATURE_STEP=0.1
RETRY_INJECT_ERROR=true

# ---------------------------------------------------------------------------
# FEATURES
# ---------------------------------------------------------------------------

# Enable reflection stage for semantic validation
REFLECT_ENABLED=true

# Use cloud model for reflection (more reliable)
REFLECT_USE_CLOUD=true

# Clarification dialogue for ambiguous prompts
CLARIFICATION_MAX_ROUNDS=3

# MCP tool result character limit (prevents context overflow)
MCP_MAX_TOOL_RESULT_CHARS=3000

# ---------------------------------------------------------------------------
# OUTPUT CONFIGURATION
# ---------------------------------------------------------------------------

# Default output directory
DEFAULT_OUTPUT_DIR=./output

# Run state persistence
RUN_STATE_INLINE_CONTEXT_MAX_CHARS=40000
RUN_STATE_CONTEXT_PREVIEW_CHARS=500
